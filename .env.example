DATABASE_URL="postgresql://postgres:postgres@localhost:5432/express-midtrans?schema=public"
PORT=3000
SESSION_SECRET="replace-with-strong-random-secret"

GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/callback/google"

MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_WEBHOOK_URL="http://localhost:3000/api/payment/webhook"
SUBSCRIPTION_GRACE_DAYS="3"
SUBSCRIPTION_DEFAULT_MONTHLY_CODE="monthly"
SUBSCRIPTION_DEFAULT_YEARLY_CODE="yearly"
FX_API_URL="https://api.fxratesapi.com/latest"
FX_API_KEY=""
FX_API_KEY_PARAM="api_key"
FX_BASE_CURRENCY="USD"
FX_TARGET_CURRENCY="IDR"
FX_TARGET_PARAM="symbols"
FX_TIMEOUT_MS="5000"
FX_CACHE_TTL_MS="300000"
FX_FAIL_CLOSE="true"
