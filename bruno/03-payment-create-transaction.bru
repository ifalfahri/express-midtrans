meta {
  name: 03 Payment Create Transaction
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/payment/create-transaction
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "amount": {{paymentAmount}},
    "enabledPayments": ["qris", "gopay", "credit_card", "bank_transfer"]
  }
}

settings {
  encodeUrl: true
  followRedirects: true
}
